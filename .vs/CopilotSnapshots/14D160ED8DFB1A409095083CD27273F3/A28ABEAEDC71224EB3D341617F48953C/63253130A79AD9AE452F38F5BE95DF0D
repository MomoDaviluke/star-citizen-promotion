:root {
  --bg: #070b14;
  --panel: #10192a;
  --text: #e7edf7;
  --text-muted: #9cb0cc;
  --line: #273750;
  --accent: #4ea1ff;
  --accent-2: #88f8ff;
}

* {
  box-sizing: border-box;
}

html,
body,
#app {
  margin: 0;
  min-height: 100%;
}

body {
  font-family: "Segoe UI", "PingFang SC", "Microsoft YaHei", sans-serif;
  background: radial-gradient(circle at top, #0f1a2f 0%, var(--bg) 45%);
  color: var(--text);
  line-height: 1.6;
}

a {
  color: inherit;
  text-decoration: none;
}

.container {
  width: min(1100px, calc(100% - 2rem));
  margin-inline: auto;
}

.app-shell {
  min-height: 100vh;
  display: grid;
  grid-template-rows: auto 1fr auto;
}

.page-main {
  padding-block: 2rem 3rem;
}

.page-title {
  margin-bottom: 1.25rem;
}

.page-title h1 {
  margin: 0;
  font-size: clamp(1.75rem, 3vw, 2.4rem);
}

.page-title p {
  color: var(--text-muted);
  margin-top: 0.5rem;
}

.grid {
  display: grid;
  gap: 1rem;
}

.card {
  border: 1px solid var(--line);
  border-radius: 12px;
  background: linear-gradient(160deg, rgba(255, 255, 255, 0.03), rgba(255, 255, 255, 0.01));
  padding: 1rem;
}

.btn {
  display: inline-block;
  border: 1px solid var(--accent);
  border-radius: 10px;
  padding: 0.55rem 0.9rem;
  transition: all 0.2s ease;
}

.btn:hover {
  background: rgba(78, 161, 255, 0.12);
}

.btn-primary {
  background: var(--accent);
  color: #05142d;
  font-weight: 700;
}

.btn-primary:hover {
  background: #70b4ff;
}
